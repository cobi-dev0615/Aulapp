<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cv_practice_class_class_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:layout_marginHorizontal="16dp"
    app:cardBackgroundColor="@color/dark_grey"
    app:cardCornerRadius="8dp"
    app:strokeColor="@color/medium_grey"
    app:strokeWidth="1dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/cl_class_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp">
        <ImageView
            android:id="@+id/iv_practice_class_icon_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_wheel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:id="@+id/tv_practice_class_title_class_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/txt_practice_exams_title_class_card"
            android:fontFamily="@font/montserrat_regular"
            android:layout_marginStart="6dp"
            app:layout_constraintStart_toEndOf="@+id/iv_practice_class_icon_card"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="@+id/tv_practice_class_title_class_card"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toStartOf="@+id/tv_practice_class_title_class_card"
            app:layout_constraintTop_toBottomOf="@+id/tv_practice_class_title_class_card">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/white"
                android:id="@+id/title_total_hours_perfomed_wheel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/include_apprentice_name_margin_top"
                android:text="@string/txt_card_hours_performed"
                android:fontFamily="@font/montserrat_regular"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/white"
                android:id="@+id/total_hours_perfomed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/include_apprentice_name_margin_top"
                android:text="@string/txt_total_hours_perfomed"
                android:fontFamily="@font/montserrat_regular"
                android:layout_marginStart="10dp"
                app:flow_horizontalBias="0"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
