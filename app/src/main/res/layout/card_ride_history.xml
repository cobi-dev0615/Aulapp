<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cv_practice_class_class_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/cv_container_class_card_background_color"
    app:cardCornerRadius="8dp"
    app:strokeColor="@color/dark_grey"
    app:strokeWidth="1dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/cl_class_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp">
        <ImageView
            android:id="@+id/iv_practice_class_icon_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_car"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:id="@+id/tv_practice_class_title_class_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_title_name_exam"
            android:fontFamily="@font/montserrat_regular"
            android:layout_marginStart="6dp"
            app:layout_constraintStart_toEndOf="@+id/iv_practice_class_icon_card"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textAppearance="@style/tv_class_type_description_appearance"
            android:id="@+id/tv_class_type_intervalo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_class_type_description_text"
            app:layout_constraintStart_toStartOf="@+id/tv_practice_class_title_class_card"
            app:layout_constraintTop_toBottomOf="@+id/tv_practice_class_title_class_card"/>
        <TextView
            android:textAppearance="@style/tv_class_type_description_appearance"
            android:id="@+id/tv_class_type_duration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/tv_class_type_duration_text"
            android:layout_marginStart="3dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_class_type_intervalo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_class_type_intervalo"
            app:layout_constraintTop_toTopOf="@+id/tv_class_type_intervalo"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_name_apprentice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Nombre aprendiz"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="@+id/tv_class_type_intervalo"
            app:layout_constraintTop_toBottomOf="@+id/tv_class_type_intervalo"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_cell_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre aprendiz"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="@+id/tv_name_apprentice"
            app:layout_constraintTop_toBottomOf="@+id/tv_name_apprentice"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre aprendiz"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="@+id/tv_cell_number"
            app:layout_constraintTop_toBottomOf="@+id/tv_cell_number"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_track"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre aprendiz"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="@+id/tv_category"
            app:layout_constraintTop_toBottomOf="@+id/tv_category"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_vehicle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre aprendiz"
            android:fontFamily="@font/montserrat_bold"
            app:layout_constraintStart_toStartOf="@+id/tv_track"
            app:layout_constraintTop_toBottomOf="@+id/tv_track"/>
        <include
            android:id="@+id/include_show_history_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_vehicle"
            layout="@layout/primary_button_start_class"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
