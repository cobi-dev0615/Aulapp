<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardBackgroundColor="@color/default_card_background_class_in_course"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="true">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/containerQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:id="@+id/question_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_question_sample"
                android:fontFamily="@font/montserrat_regular"/>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioGroup
                    android:orientation="horizontal"
                    android:id="@+id/statusCheck"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp">
                    <RadioButton
                        android:theme="@style/CustomRadioButtonStyle"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:id="@+id/rejectRadioButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:button="@drawable/custom_radio_button_rejected_drawable"
                        android:text="@string/txt_disapprove"
                        android:fontFamily="@font/montserrat_regular"/>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>
                    <RadioButton
                        android:theme="@style/CustomRadioButtonStyle"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:id="@+id/approveRadioButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:button="@drawable/custom_radio_button_approved_drawable"
                        android:text="@string/txt_approve"
                        android:fontFamily="@font/montserrat_regular"
                        android:layout_marginEnd="10dp"/>
                </RadioGroup>
            </LinearLayout>
            <com.ncorti.slidetoact.SlideToActView
                android:id="@+id/next_button_swipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:animation_duration="250"
                app:area_margin="0dp"
                app:border_radius="2dp"
                app:inner_color="@color/colorCurrent"
                app:outer_color="@color/dark_blue"
                app:slider_height="50dp"
                app:slider_icon_color="@color/white"
                app:slider_locked="false"
                app:text="@string/txt_slide_to_next"
                app:text_appearance="@font/montserrat_regular"
                app:text_color="@color/white"
                app:text_size="20sp"
                app:text_style="bold"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/containerQuestionCompleted"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:background="@drawable/ic_image_question_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:contentDescription="TODO"/>
            <TextView
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/txt_items_rated"
                android:fontFamily="@font/montserrat_regular"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
