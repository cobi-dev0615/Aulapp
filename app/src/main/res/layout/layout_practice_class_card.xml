<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_practice_class_class_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/CustomCardViewClassProgress">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@+id/cl_class_card"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="16dp">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/ln_class_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/iv_practice_class_icon_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_car"/>
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/green"
                    android:id="@+id/tv_practice_class_title_class_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Práctica"
                    android:fontFamily="@font/montserrat_regular"
                    android:layout_marginStart="6dp"
                    app:layout_constraintStart_toEndOf="@+id/iv_practice_class_icon_card"
                    app:layout_constraintTop_toTopOf="parent"/>
            </LinearLayout>
            <include
                android:id="@+id/include_practice_class_apprentice"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ln_class_card"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_instructor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_apprentice"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_category"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_instructor"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_vehicle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_category"
                layout="@layout/layout_class_progress_text"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/class_detail_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cv_practice_class_class_card"
        style="@style/CustomCardViewClassProgress">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@+id/cl_class_detail_card_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="16dp">
            <include
                android:id="@+id/include_practice_class_date"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_time"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_date"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_start_time"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_time"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_top_speed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_start_time"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_average_speed"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_top_speed"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_moving_time"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_average_speed"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_stopped_time"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_moving_time"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_distance_traveled"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_stopped_time"
                layout="@layout/layout_class_progress_text"/>
            <include
                android:id="@+id/include_practice_class_cea"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/include_practice_class_distance_traveled"
                layout="@layout/layout_class_progress_text"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
