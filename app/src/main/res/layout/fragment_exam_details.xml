<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/default_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="5dp">
                <include
                    android:id="@+id/card_profile_user_profile_exam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginHorizontal="@dimen/card_info_user_margin_horizontal_profile_user"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    layout="@layout/card_profile_user_layout"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/container_rv_list_apprentices"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginHorizontal="@dimen/card_info_user_margin_horizontal_profile_user"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintStart_toStartOf="@+id/card_profile_user_profile_exam"
                    app:layout_constraintTop_toBottomOf="@+id/card_profile_user_profile_exam">
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        style="@style/CustomCardViewWithoutStroke">
                        <TextView
                            android:textAppearance="@style/text_medium_green"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="15dp"
                            android:text="@string/title_details_apprentices"/>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_details_apprentices"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="50dp"
                            android:layout_marginHorizontal="@dimen/margin_horizontal_recycler_view_step_profile_user"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <include
                    android:id="@+id/card_item_exam_details"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginHorizontal="@dimen/card_info_user_margin_horizontal_profile_user"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintStart_toStartOf="@+id/card_profile_user_profile_exam"
                    app:layout_constraintTop_toBottomOf="@+id/card_profile_user_profile_exam"
                    layout="@layout/card_item_exam_details_layout"/>
                <include
                    android:id="@+id/include_primary_button_exam_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="380dp"
                    android:text="@string/dialog_fullscreen_recovery_password_title_button_success"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_button_login"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/card_profile_user_profile_exam"
                    layout="@layout/primary_button"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>
