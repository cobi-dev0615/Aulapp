<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:textSize="16dp"
        android:textColor="@color/white"
        android:id="@+id/txt_type_process_biometrics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginStart="16dp"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/container_detail_user"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="100dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#364151"
        app:cardCornerRadius="15dp">
        <ImageView
            android:id="@+id/img_rol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginStart="10dp"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/txt_user_rol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="50dp"/>
        <TextView
            android:id="@+id/txt_user_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="Maria Paula Forero Ramirez"
            android:maxLines="2"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/txt_user_type_document"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="115dp"
            android:text="@string/text_type_document"
            android:layout_marginStart="15dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/white"
            android:id="@+id/txt_user_number_document"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="115dp"
            android:text="@string/text_document_number"
            android:layout_marginStart="60dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/white"
            android:id="@+id/txt_user_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="145dp"
            android:layout_marginStart="15dp"/>
    </androidx.cardview.widget.CardView>

    <!-- Photo Selection Label -->
    <TextView
        android:textSize="18sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:id="@+id/text_hand_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="300dp"
        android:text="Seleccionar foto de galería"/>

    <!-- Photo Preview -->
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="@+id/card_photo_preview"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <ImageView
            android:id="@+id/img_hand_type"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_hand_left"
            android:contentDescription="Foto seleccionada"/>
    </androidx.cardview.widget.CardView>

    <!-- Select Photo Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_select_photo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="120dp"
        android:layout_marginHorizontal="32dp"
        android:text="Seleccionar foto"
        android:textAllCaps="false"
        app:icon="@android:drawable/ic_menu_gallery"
        app:iconGravity="textStart"
        style="@style/Widget.Material3.Button.OutlinedButton"/>

    <!-- Confirm Button -->
    <include
        android:layout_gravity="bottom"
        android:id="@+id/include_primary_button_biometric_registration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="50dp"
        android:text="@string/title_mb_login"
        android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_button_login"
        layout="@layout/primary_button"/>
</FrameLayout>
