<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_item_step_profile"
        android:layout_width="match_parent"
        android:layout_height="@dimen/card_step_profile_height"
        style="@style/CustomCardViewWithoutStroke">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:id="@+id/iv_icon_card_item_step_profile"
                android:background="@drawable/ic_qr_code"
                android:layout_marginHorizontal="@dimen/icon_card_step_profile_margin_horizontal"
                android:layout_marginVertical="@dimen/icon_card_step_profile_margin_vertical"
                style="@style/IconCardStepInactive"/>
            <TextView
                android:ellipsize="end"
                android:id="@+id/tv_card_item_step_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/register_biometric"
                android:maxLines="2"
                android:layout_marginEnd="@dimen/text_card_step_profile_margin_end"
                android:layout_marginVertical="@dimen/text_card_step_profile_margin_vertical"
                style="@style/text_card_item_step_profile_user_inactive"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>
