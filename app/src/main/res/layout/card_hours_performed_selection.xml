<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/dark_grey"
    app:statusBarBackground="@color/dark_grey"
    app:strokeColor="@color/dark_grey">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp">
        <TextView
            android:textSize="20sp"
            android:textColor="@color/light_blue"
            android:id="@+id/tv_name_cea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_title_name_cea"
            android:fontFamily="@font/montserrat"
            android:layout_marginStart="20dp"/>
        <include
            android:id="@+id/include_hour_perfomed_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            layout="@layout/layout_hour_performed_text"/>
        <include
            android:id="@+id/include_hour_perfomed_cellphone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            layout="@layout/layout_hour_performed_text"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_detail_hours"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
