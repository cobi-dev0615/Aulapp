<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/first_login_fragment"
    android:background="@drawable/gradient_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <RelativeLayout
            android:id="@+id/layoutContainerWidger"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBaseline_toBottomOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="5dp">
                    <ImageView
                        android:id="@+id/iv_logo_aulapp_login"
                        android:layout_width="160dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="@dimen/dimen_margin_top_logo_login"
                        android:src="@drawable/ic_aulapp"
                        android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_login"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <ImageView
                        android:id="@+id/iv_image_login"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dimen_margin_top_image_login"
                        android:src="@drawable/ic_login_image"
                        android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_login"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_logo_aulapp_login"/>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/constraint_all_menu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_information_login"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_image_login">
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/constraint_menu_login"
                                android:visibility="visible"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="23dp"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp">
                                <TextView
                                    android:textAppearance="@style/style_helper_text_user"
                                    android:id="@+id/tv_helper_document_number"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/helper_text_document_number"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"/>
                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/til_text_input_user_login"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tv_helper_document_number"
                                    app:startIconContentDescription="@string/content_description_icon_user_input"
                                    style="@style/OutlinedRoundedBox">
                                    <com.google.android.material.textfield.TextInputEditText
                                        android:enabled="true"
                                        android:id="@+id/tiet_text_input_user_login"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="textEmailAddress"
                                        android:backgroundTint="@color/background_ceas"
                                        style="@style/input_primary"/>
                                </com.google.android.material.textfield.TextInputLayout>
                            </androidx.constraintlayout.widget.ConstraintLayout>
                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/constraint_menu_cea"
                                android:visibility="gone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp">
                                <TextView
                                    android:textAppearance="@style/style_helper_text_user"
                                    android:id="@+id/tv_helper_cea"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/helper_text_cea"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"/>
                                <include
                                    android:id="@+id/include_dropdown_cea"
                                    android:layout_width="match_parent"
                                    android:layout_height="52dp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tv_helper_cea"
                                    layout="@layout/general_dropdown"/>
                            </androidx.constraintlayout.widget.ConstraintLayout>
                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:id="@+id/constraint_menu_password"
                                android:visibility="visible"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:textAlignment="center"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp">
                                <TextView
                                    android:textAppearance="@style/style_helper_text_user"
                                    android:id="@+id/tv_helper_password"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/helper_text_password"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent"/>
                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/til_text_input_user_password"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tv_helper_password"
                                    app:startIconContentDescription="@string/content_description_icon_user_input"
                                    style="@style/OutlinedRoundedBox">
                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/tiet_text_input_user_password"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="textPassword"
                                        android:backgroundTint="@color/background_ceas"
                                        style="@style/input_primary"/>
                                </com.google.android.material.textfield.TextInputLayout>
                            </androidx.constraintlayout.widget.ConstraintLayout>
                            <LinearLayout
                                android:gravity="center"
                                android:orientation="horizontal"
                                android:id="@+id/ll_recovery_login"
                                android:visibility="visible"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="18dp"
                                android:baselineAligned="true"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/til_text_input_password_login">
                                <ImageView
                                    android:id="@+id/iv_icon_recovery_login"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/ic_key"
                                    android:layout_marginEnd="@dimen/dimen_margin_end_icon_recovery_password_login"/>
                                <com.google.android.material.textview.MaterialTextView
                                    android:id="@+id/mtv_link_recovery_password_login"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/content_recovery_link"
                                    style="@style/link_recovery_password_login"/>
                            </LinearLayout>
                            <TextView
                                android:layout_gravity="center"
                                android:id="@+id/tv_information_login"
                                android:visibility="visible"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:layout_marginBottom="1dp"
                                android:layout_marginHorizontal="20dp"
                                style="@style/title_information_login"/>
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <include
                        android:id="@+id/include_primary_button_login"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="18dp"
                        android:text="@string/title_mb_login"
                        android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_button_login"
                        app:layout_constraintTop_toBottomOf="@+id/constraint_all_menu"
                        layout="@layout/primary_button"/>
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/mtv_version_app_login"
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@+id/include_primary_button_login"
                        style="@style/title_version_app"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>
