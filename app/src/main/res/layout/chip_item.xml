<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.chip.Chip xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:enabled="true"
    android:textColor="@color/transparent"
    android:id="@+id/chip_general"
    android:clickable="true"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:checkedIcon="@null"
    app:chipBackgroundColor="@color/dark_chip"
    app:chipIcon="@null"
    app:chipMinTouchTargetSize="0dp"
    app:chipStrokeColor="@color/dark_chip"
    app:chipSurfaceColor="@android:color/transparent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    style="@style/CustomChip"/>
