<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/dark_grey"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp">
                <include
                    android:id="@+id/card_profile_user_profile_user"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/card_info_user_margin_horizontal_profile_user"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    layout="@layout/card_profile_user_layout"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint_menu_biometric_process"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="42dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:id="@+id/tv_title_current_hand"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/title_left_hand"
                        app:layout_constraintTop_toTopOf="parent"
                        style="@style/Title_left_right_hand"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="42dp"
                        android:layout_marginHorizontal="16dp">
                        <ImageButton
                            android:layout_gravity="center"
                            android:id="@+id/ibtn_left_hand"
                            android:background="@color/transparent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_handon"
                            android:layout_weight="1"
                            android:contentDescription="TODO"/>
                        <ImageButton
                            android:layout_gravity="center"
                            android:id="@+id/ibtn_right_hand"
                            android:background="@color/transparent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_handoff"
                            android:layout_weight="1"
                            android:contentDescription="TODO"/>
                    </LinearLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:visibility="visible"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="42dp"
                        android:layout_marginHorizontal="16dp">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ToggleButton
                                android:enabled="false"
                                android:textColor="@color/white"
                                android:id="@+id/tbtn_rectangle_1"
                                android:tag="@string/tag_rectangle_uncheck"
                                android:background="@color/transparent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textOff="@string/title_button_rectangle_1"
                                android:drawableTop="@drawable/ic_rectangle"
                                android:layout_weight="1"/>
                            <ToggleButton
                                android:enabled="false"
                                android:textColor="@color/white"
                                android:id="@+id/tbtn_rectangle_2"
                                android:tag="@string/tag_rectangle_uncheck"
                                android:background="@color/transparent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textOff="@string/title_button_rectangle_2"
                                android:drawableTop="@drawable/ic_rectangle"
                                android:layout_weight="1"/>
                            <ToggleButton
                                android:enabled="false"
                                android:textColor="@color/white"
                                android:id="@+id/tbtn_rectangle_3"
                                android:tag="@string/tag_rectangle_uncheck"
                                android:background="@color/transparent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textOff="@string/title_button_rectangle_3"
                                android:drawableTop="@drawable/ic_rectangle"
                                android:layout_weight="1"/>
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <include
                android:id="@+id/include_primary_button_verify_finger"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="79dp"
                android:layout_marginBottom="48dp"
                android:text="@string/title_mb_login"
                android:layout_marginHorizontal="21dp"
                layout="@layout/primary_button"/>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
