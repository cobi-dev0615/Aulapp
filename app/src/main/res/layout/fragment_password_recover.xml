<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/gradient_background"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp">
                <ImageView
                    android:id="@+id/iv_logo_aulapp_recovery"
                    android:layout_width="160dp"
                    android:layout_height="47dp"
                    android:layout_marginTop="35dp"
                    android:src="@drawable/ic_aulapp"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_login"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.497"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <ImageView
                    android:id="@+id/iv_image_recovery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp"
                    android:src="@drawable/ic_login_image"
                    android:layout_marginStart="100dp"
                    android:layout_marginEnd="100dp"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_login"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/iv_logo_aulapp_recovery"/>
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/mtv_text_title_recovery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="@string/content_recovery_text_title"
                    android:textAlignment="center"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.483"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/iv_image_recovery"
                    style="@style/link_recovery_password_login"/>
                <include
                    android:id="@+id/include_general_text_input_user_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_input_user_login"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/mtv_text_title_recovery"
                    app:startIconContentDescription="@string/content_description_icon_user_input"
                    layout="@layout/general_text_input"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_text_input_user_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_input_user_login"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/mtv_text_title_recovery"
                    app:startIconContentDescription="@string/content_description_icon_user_input"
                    style="@style/OutlinedRoundedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tiet_text_input_user_recovery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        style="@style/input_primary"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/mtv_information_recovery"
                    android:visibility="invisible"
                    android:layout_width="@dimen/dimen_0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/dummy_error_login"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_information_login"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/include_general_text_input_user_recovery"
                    style="@style/title_information_login"/>
                <include
                    android:id="@+id/include_primary_button_recovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_margin_top_button_login"
                    android:text="@string/title_mb_login"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_button_login"
                    app:layout_constraintBottom_toTopOf="@+id/mtv_version_app_recovery"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/mtv_information_recovery"
                    layout="@layout/primary_button"/>
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/mtv_version_app_recovery"
                    android:visibility="visible"
                    android:layout_width="@dimen/dimen_0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_margin_top_version_app"
                    android:layout_marginBottom="@dimen/dimen_margin_bottom_version_app"
                    android:layout_marginHorizontal="@dimen/dimen_margin_horizontal_version_app"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/include_primary_button_recovery"
                    app:layout_constraintVertical_bias="1"
                    style="@style/title_version_app"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
