<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/constraint_menu_select_hand"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="64dp"
    android:layout_marginHorizontal="16dp">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/tv_title_select_hand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_choose_hand"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Title_left_right_hand"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_left_hand"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="40dp">
            <ImageView
                android:id="@+id/imageViewLeftHand"
                android:tag="@string/tag_hand_uncheck"
                android:background="@drawable/ic_left_hand_off_with_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <TextView
                android:id="@+id/tv_imageViewLeftHand"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/title_left_hand"
                android:textAlignment="center"
                android:layout_marginStart="144dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/imageViewLeftHand"
                app:layout_constraintStart_toStartOf="@+id/imageViewLeftHand"
                app:layout_constraintTop_toTopOf="@+id/imageViewLeftHand"
                style="@style/Title_left_right_hand_disable"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/container_right_hand"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="24dp">
            <ImageView
                android:id="@+id/imageViewRightHand"
                android:tag="@string/tag_hand_uncheck"
                android:background="@drawable/ic_right_hand_off_with_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <TextView
                android:id="@+id/tv_imageViewRightHand"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="@string/title_right_hand"
                android:layout_marginEnd="144dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/Title_left_right_hand_disable"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:id="@+id/tv_choose_hand_error"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="55dp"
            android:text="@string/title_choose_hand_error"
            android:layout_marginHorizontal="19dp"
            style="@style/title_choose_hand_error"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
