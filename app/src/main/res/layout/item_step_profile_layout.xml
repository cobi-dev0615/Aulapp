<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/v_line_up_item_step_profile"
        android:background="@color/grey"
        android:layout_width="3dp"
        android:layout_height="22dp"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/iv_ic_circle_item_step_profile"
        android:background="@drawable/ic_circle"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginVertical="8dp"
        app:layout_constraintBottom_toTopOf="@+id/v_line_down_item_step_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/v_line_up_item_step_profile"/>
    <View
        android:id="@+id/v_line_down_item_step_profile"
        android:background="@color/grey"
        android:layout_width="3dp"
        android:layout_height="22dp"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <include
        android:id="@+id/include_container_two_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginVertical="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_ic_circle_item_step_profile"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/card_item_step_profile_layout"/>
</androidx.constraintlayout.widget.ConstraintLayout>
