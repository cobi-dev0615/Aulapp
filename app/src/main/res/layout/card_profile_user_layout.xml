<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/transparent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_notification_detail"
        app:contentPaddingBottom="16dp"
        style="@style/CustomCardViewWithStroke">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ll_body_card_profile_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/iv_icon_user_card_profile_user"
                    android:layout_width="29dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="17dp"/>
                <TextView
                    android:textAppearance="@style/body_item_instructor_user_query"
                    android:ellipsize="end"
                    android:id="@+id/tv_profile_card_profile_user_card_profile_user"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="@string/profile_trainee"
                    android:maxLines="1"
                    android:layout_marginStart="14dp"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/text_medium_green"
                android:ellipsize="end"
                android:id="@+id/tv_name_card_profile_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/name"
                android:maxLines="2"
                android:layout_marginStart="16dp"/>
            <TextView
                android:textAppearance="@style/text_small_green"
                android:ellipsize="end"
                android:id="@+id/tv_id_number_card_profile_user"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/id_number_dummy"
                android:maxLines="1"
                android:layout_marginStart="16dp"/>
            <TextView
                android:textAppearance="@style/text_small_white"
                android:ellipsize="end"
                android:id="@+id/tv_email_card_profile_user"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/email_dummy"
                android:maxLines="1"
                android:layout_marginStart="16dp"/>
            <TextView
                android:textAppearance="@style/text_small_white"
                android:ellipsize="end"
                android:id="@+id/tv_grade_card_profile_user"
                android:visibility="visible"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/grade_dummy"
                android:maxLines="1"
                android:layout_marginStart="16dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.appcompat.widget.LinearLayoutCompat>
